# Database
DB_CLIENT=postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres

# Server
PORT=3000

# Admin authentication
ADMIN_TOKEN=your-secure-admin-token-here

# URLs
FRONTEND_URL=https://www.jeiziproductions.dev
ADMIN_URL=https://admin.jeiziproductions.dev

# Local development (for Vite proxy, leave empty for same-origin in production)
# VITE_API_BASE_URL=http://localhost:3000

